# Required: Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Required: Telegram Chat ID (get from /start command)
TELEGRAM_CHAT_ID=your_chat_id_here

# Optional: Trading symbol (default: BTCUSDT)
TRADING_SYMBOL=BTCUSDT

# Optional: Model settings
PREDICTION_THRESHOLD=0.52
RETRAIN_INTERVAL_HOURS=6
LOOKBACK_CANDLES=100

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: Polymarket auto-trading
# Set POLYMARKET_PRIVATE_KEY to enable Polymarket integration.
# Without it, the bot works normally — just signals, no trading.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=2
